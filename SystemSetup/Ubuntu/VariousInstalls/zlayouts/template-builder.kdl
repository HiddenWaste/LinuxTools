layout {
 pane {
        split_direction "vertical"
        pane cwd="~/Code/LinuxTools/SystemSetup/zlayouts"
	    pane split_direction="horizontal" {
	        pane {
                split_direction "vertical"
                pane name="Launch" cwd="~/Code/Linuxtools/SystemSetup/zlayouts"
	            pane name="-" command="~/Code/LinuxTools/Bonsai/SmolBonsai.sh"
            }
            pane name="-" command="cmatrix"
        }
    }
}


